testing_label_vector = cvtLabel(s(3), s(4))';
testing_instance_matrix = reshape(imgs, s(1)*s(2), s(3)*s(4))';


[predicted_label, accuracy, a] = ...
    liblinear_predict(testing_label_vector, sparse(testing_instance_matrix), model);
