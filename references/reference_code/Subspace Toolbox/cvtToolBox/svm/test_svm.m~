clear;
load('face.mat');

s = size(imgs);

training_label_vector = cvtLabel(s(3), s(4))';
training_instance_matrix = reshape(imgs, s(1)*s(2), s(3)*s(4))';

model = liblinear_train(training_label_vector, ...
              sparse(training_instance_matrix), ...
              ['-s 4', 'col']);
          
